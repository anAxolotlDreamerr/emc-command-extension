{
	"schemaVersion": 1,
	"id": "emccommandextension",
	"version": "${version}",
	"name": "Emc Command Extension",
	"description": "This mod extends EarthMC commands and allows you to use them anytime.",
	"authors": [
		"AxolotlDreamer"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "MIT",
	"icon": "assets/emccommandextension/icon.png",
	"environment": "client",
	"entrypoints": {
		"main": [
			"io.github.anaxolotldreamerr.EmcCommandExtension"
		],
		"client": [
			"io.github.anaxolotldreamerr.client.EmcCommandExtensionClient"
		]
	},
	"mixins": [
		"emccommandextension.mixins.json",
		{
			"config": "emccommandextension.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.2",
		"minecraft": "~1.21.8",
		"java": ">=21",
		"fabric-api": "*",
		"malilib": ">=0.27.7"
	}
}